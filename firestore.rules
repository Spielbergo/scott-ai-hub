rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Market trend data — readable by anyone, writable only by admin/functions
    match /marketTrends/{document=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Agent activity logs — readable by authenticated users
    match /agentLogs/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; // functions only via Admin SDK
    }

    // Agent status — readable by authenticated users
    match /agentStatus/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; // functions only via Admin SDK
    }
  }
}
